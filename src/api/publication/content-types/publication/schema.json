{
  "kind": "collectionType",
  "collectionName": "publications",
  "info": {
    "singularName": "publication",
    "pluralName": "publications",
    "displayName": "Publicación",
    "description": "Revista de la Edad de Plata española"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "titulo": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "titulo",
      "required": true
    },
    "descripcion": {
      "type": "blocks"
    },
    "imagen_portada": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "año_inicio": {
      "type": "integer"
    },
    "año_fin": {
      "type": "integer"
    },
    "lugar_publicacion": {
      "type": "string"
    },
    "latitud": {
      "type": "decimal"
    },
    "longitud": {
      "type": "decimal"
    },
    "lugar_publicacion_2": {
      "type": "string"
    },
    "latitud_2": {
      "type": "decimal"
    },
    "longitud_2": {
      "type": "decimal"
    },
    "notas": {
      "type": "text"
    },
    "metadatos_marc21": {
      "type": "text"
    },
    "id_revista_legado": {
      "type": "integer"
    },
    "periodicidad": {
      "type": "string"
    },
    "numeros_publicados": {
      "type": "integer"
    },
    "fecha_primer_numero": {
      "type": "date"
    },
    "fecha_ultimo_numero": {
      "type": "date"
    },
    "issn": {
      "type": "string"
    },
    "idioma": {
      "type": "string"
    },
    "mostrar_en_home": {
      "type": "boolean",
      "default": false
    },
    "orden_home": {
      "type": "integer"
    },
    "issues": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::issue.issue",
      "mappedBy": "publication"
    },
    "materias": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::materia.materia",
      "inversedBy": "publicaciones"
    },
    "directores": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::author.author",
      "inversedBy": "revistas_dirigidas"
    },
    "impresores": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::author.author",
      "inversedBy": "revistas_impresas"
    }
  }
}
