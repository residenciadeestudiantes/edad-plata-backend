{
  "kind": "collectionType",
  "collectionName": "temas",
  "info": {
    "singularName": "tema",
    "pluralName": "temas",
    "displayName": "Tema",
    "description": "Categoría temática de un artículo (ciencia, historia, arte, crítica...), asignada por clasificación automática con LLM y corregible a mano"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "nombre": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "slug": {
      "type": "uid",
      "targetField": "nombre",
      "required": true
    },
    "articles": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::article.article",
      "mappedBy": "temas"
    }
  }
}
