{
  "kind": "collectionType",
  "collectionName": "personas_mencionadas",
  "info": {
    "singularName": "persona-mencionada",
    "pluralName": "personas-mencionadas",
    "displayName": "PersonaMencionada",
    "description": "Persona real mencionada en el texto de un artículo (no autora de ese artículo), extraída automáticamente para el análisis de contenido"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "nombre": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "slug": {
      "type": "uid",
      "targetField": "nombre",
      "required": true
    },
    "articles": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::article.article",
      "mappedBy": "personas_mencionadas"
    }
  }
}
