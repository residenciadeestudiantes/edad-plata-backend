{
  "kind": "collectionType",
  "collectionName": "articles",
  "info": {
    "singularName": "article",
    "pluralName": "articles",
    "displayName": "Artículo",
    "description": "Artículo publicado en un número de una revista de la Edad de Plata española"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "titulo": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "titulo",
      "required": true
    },
    "texto": {
      "type": "text"
    },
    "posicion": {
      "type": "integer"
    },
    "pagina_inicio": {
      "type": "integer"
    },
    "pagina_fin": {
      "type": "integer"
    },
    "imagenes": {
      "type": "media",
      "multiple": true,
      "allowedTypes": ["images"]
    },
    "id_articulo_legado": {
      "type": "integer"
    },
    "issue": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::issue.issue",
      "inversedBy": "articles"
    },
    "authors": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::author.author",
      "inversedBy": "articles"
    }
  }
}
