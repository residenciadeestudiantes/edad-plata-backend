# Variables que usa docker-compose.yml (sustitución ${VAR}) y que se pasan
# a los contenedores. NO confundir con el .env del backend en sí (el que
# tiene APP_KEYS, *_SECRET, *_SALT, ENCRYPTION_KEY): ese sigue viviendo en
# ../.env y se monta dentro del contenedor backend con `env_file`.

# Dominios públicos (deben resolver por DNS a la IP de este servidor antes
# de levantar Caddy, o el certificado de Let's Encrypt fallará).
DOMAIN_APP=tu-dominio.com
DOMAIN_API=api.tu-dominio.com
LETSENCRYPT_EMAIL=tu-email@tu-dominio.com

# Credenciales de la base de datos PostgreSQL (contenedor postgres). Genera
# una contraseña nueva, no reutilices ninguna de desarrollo.
DATABASE_NAME=strapi
DATABASE_USERNAME=strapi
DATABASE_PASSWORD=cambia-esto
